# Keep the real key in .env; never commit it.
OPENAI_API_KEY=

# Lightweight article glosses and missing vocabulary meanings.
OPENAI_FAST_MODEL=gpt-5.6-luna

# High-quality Japanese reading. The browser never receives this key.
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_v3

# Optional: pin two Japanese voices from ElevenLabs My Voices / Voice Library.
# If omitted, the server selects the best verified Japanese voices available to the account.
ELEVENLABS_JA_VOICE_A=
ELEVENLABS_JA_VOICE_B=
